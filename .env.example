# .env.example
# Copia este archivo a .env y completa las credenciales
# El .env NUNCA se sube a git

# ─────────────────────────────────────────────
# Motor de base de datos
# Valores válidos: postgres | sqlserver | mariadb | mysql
# ─────────────────────────────────────────────
DB_ENGINE=postgres

# ─────────────────────────────────────────────
# Rutas de datos — solo Escenario A (Docker completo)
#
# docker-compose sobreescribe estos valores automáticamente.
# No necesitas cambiarlos.
#
# En Escenario B define las rutas de los archivos directamente
# en config/pipeline.yaml usando rutas absolutas:
#   file: "/home/usuario/datos/clientes.csv"
# ─────────────────────────────────────────────
BULK_PATH_HOST=/app/data
BULK_PATH_CONTAINER=/data

# ─────────────────────────────────────────────
# SQL Server
# ─────────────────────────────────────────────
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=TuPassword123!
SQLSERVER_DB=flowelt_demo

# ─────────────────────────────────────────────
# PostgreSQL
# localhost:5433  → BD local o Docker con puerto mapeado
# flowelt_postgres:5432 → red interna Docker (lo sobreescribe docker-compose)
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=TuPassword123!
POSTGRES_DB=flowelt_demo

# ─────────────────────────────────────────────
# MariaDB
# localhost:3307  → BD local o Docker con puerto mapeado
# flowelt_mysql:3306 → red interna Docker (lo sobreescribe docker-compose)
# ─────────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3307
MARIADB_USER=admin
MARIADB_ROOT_PASSWORD=TuPassword123!
MARIADB_PASSWORD=TuPassword123!
MARIADB_DB=flowelt_demo

# ─────────────────────────────────────────────
# MySQL 8
# localhost:3308  → BD local o Docker con puerto mapeado
# flowelt_mysql8:3306 → red interna Docker (lo sobreescribe docker-compose)
# ─────────────────────────────────────────────
MYSQL_HOST=localhost
MYSQL_PORT=3308
MYSQL_USER=admin
MYSQL_ROOT_PASSWORD=TuPassword123!
MYSQL_PASSWORD=TuPassword123!
MYSQL_DB=flowelt_demo
