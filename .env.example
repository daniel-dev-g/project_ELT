# .env.example
# Copia este archivo a .env y completa las credenciales
# El .env NUNCA se sube a git

# ─────────────────────────────────────────────
# SQL Server
# ─────────────────────────────────────────────
SQLSERVER_HOST=localhost
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=TuPassword123!

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=TuPassword123!
POSTGRES_DB=demo_db

# ─────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────
MYSQL_USER=admin
MYSQL_ROOT_PASSWORD=TuPassword123!
MYSQL_PASSWORD=TuPassword123!
MYSQL_DB=demo_db

# ─────────────────────────────────────────────
# IBM Db2
# ─────────────────────────────────────────────
DB2_USER=db2inst1
DB2_PASSWORD=TuPassword123!
DB2_DB=demo_db

# ─────────────────────────────────────────────
# Oracle
# ─────────────────────────────────────────────
ORACLE_USER=system
ORACLE_PASSWORD=TuPassword123!
