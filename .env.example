# .env.example
# Copia este archivo a .env y completa las credenciales
# El .env NUNCA se sube a git

# ─────────────────────────────────────────────
# Rutas de datos (bulk_path_map)
#
# BULK_PATH_HOST      → ruta donde el contenedor Python ve los archivos
# BULK_PATH_CONTAINER → ruta donde la BD ve los mismos archivos
#
# Escenario A (Docker completo): docker-compose sobreescribe ambas automáticamente.
#                                No necesitas cambiar estos valores.
#
# Escenario B — ./data/ (predeterminado):
#   BULK_PATH_HOST=/app/data           (contenedor Python)
#   BULK_PATH_CONTAINER=<ruta absoluta del ./data/ en tu máquina>
#
# Escenario B — directorio propio (USER_DATA_PATH):
#   USER_DATA_PATH=/home/user/mis_datos          (ruta real en tu máquina)
#   BULK_PATH_HOST=/app/user_data                (como lo ve el contenedor)
#   BULK_PATH_CONTAINER=/home/user/mis_datos     (como lo ve tu BD local)
# ─────────────────────────────────────────────
BULK_PATH_HOST=/app/data
BULK_PATH_CONTAINER=/data

# Directorio externo de archivos (Escenario B con ruta propia)
# Déjalo vacío si usas el ./data/ predeterminado.
USER_DATA_PATH=

# ─────────────────────────────────────────────
# SQL Server
# ─────────────────────────────────────────────
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=TuPassword123!
SQLSERVER_DB=flowelt_demo

# ─────────────────────────────────────────────
# PostgreSQL
# localhost:5433  → BD local o Docker con puerto mapeado
# flowelt_postgres:5432 → red interna Docker (lo sobreescribe docker-compose)
# ─────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_USER=admin
POSTGRES_PASSWORD=TuPassword123!
POSTGRES_DB=flowelt_demo

# ─────────────────────────────────────────────
# MariaDB
# localhost:3307  → BD local o Docker con puerto mapeado
# flowelt_mysql:3306 → red interna Docker (lo sobreescribe docker-compose)
# ─────────────────────────────────────────────
MARIADB_HOST=localhost
MARIADB_PORT=3307
MARIADB_USER=admin
MARIADB_ROOT_PASSWORD=TuPassword123!
MARIADB_PASSWORD=TuPassword123!
MARIADB_DB=flowelt_demo
